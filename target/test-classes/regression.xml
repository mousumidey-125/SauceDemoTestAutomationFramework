<?xml version="1.0" encoding="UTF-8"?>
<suite name="Regression Suite">
	<listeners>
		<listener
			class-name="com.saucedemo.automation.utils.ExtentReportManager" />
	</listeners>
	<test name="Regression Tests">
		<groups>
			<run>
				<include name="regression" />
			</run>
		</groups>
		<classes>
			<class name="com.saucedemo.automation.tests.LoginTest" />
			<class name="com.saucedemo.automation.tests.ProductTest" />
			<class name="com.saucedemo.automation.tests.CartTest" />
		</classes>
	</test>
</suite>